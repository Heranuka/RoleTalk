# General
APP_ENV=development
APP_APP_NAME=RoleTalk-API
APP_APP_VERSION=1.0.0

# API and Client
APP_API_URL=http://localhost:8080
APP_CLIENT_URL=http://localhost:5173

# Observability (Tempo/Loki)
APP_OBSERVABILITY_ENABLED=true
APP_OBSERVABILITY_OTLP_ENDPOINT=localhost:4318
APP_OBSERVABILITY_LOKI_URL=http://localhost:3100/loki/api/v1/push

# JWT Secrets
APP_JWT_SECRET=your_very_long_random_secure_secret_string

# Logging
APP_LOGGING_LEVEL=debug

# Database (Postgres)
# Using 'db' as host for docker-compose environment
APP_POSTGRES_HOST=db
APP_POSTGRES_PORT=5432
APP_POSTGRES_USER=user
APP_POSTGRES_PASSWORD=password
APP_POSTGRES_DB=roleTalk_db
APP_DATABASE_URL=postgres://user:password@db:5432/roleTalk_db?sslmode=disable

# Storage (MinIO)
APP_MINIO_ENDPOINT=s3:9000
APP_MINIO_ACCESS_KEY=admin
APP_MINIO_SECRET_KEY=password123
APP_MINIO_BUCKET=roleTalk-storage

# OAuth (Google)
APP_Google_CLIENT_ID=your_client_id_here
APP_Google_CLIENT_SECRET=your_client_secret_here

# SMTP
APP_SMTP_USERNAME=your_smtp_user
APP_SMTP_PASSWORD=your_smtp_password

# Migrations (Goose)
GOOSE_DRIVER=postgres
GOOSE_DBSTRING=postgres://user:password@db:5432/roleTalk_db?sslmode=disable
GOOSE_MIGRATION_DIR=./migrations